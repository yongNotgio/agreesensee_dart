# AgriSense — Supabase credentials
# Copy this file to ".env" and fill in your project's values.
# (The real .env is gitignored. The anon/publishable key is safe for clients;
#  Row Level Security protects the data.)
#
# Without a .env (or --dart-define overrides) the app runs in offline demo mode.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
